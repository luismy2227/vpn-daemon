## Step 4 — The VPN Daemon
```py
import json
import time
import subprocess
import pyotp
import psutil
import os

CONFIG_FILE = "config.json"


def load_config():
    with open(CONFIG_FILE) as f:
        return json.load(f)


def generate_password(password, secret):
    totp = pyotp.TOTP(secret)
    return password + totp.now()


def vpn_running():
    for proc in psutil.process_iter(['name']):
        if proc.info['name'] and "openvpn" in proc.info['name'].lower():
            return True
    return False


def start_vpn(config):

    otp_password = generate_password(
        config["password"],
        config["totp_secret"]
    )

    with open("auth.txt", "w") as f:
        f.write(config["username"] + "\n")
        f.write(otp_password + "\n")

    subprocess.Popen([
        config["openvpn_path"],
        "--config",
        config["profile"],
        "--auth-user-pass",
        "auth.txt"
    ])

    print("VPN started")


def stop_vpn():
    for proc in psutil.process_iter(['pid', 'name']):
        if proc.info['name'] and "openvpn" in proc.info['name'].lower():
            psutil.Process(proc.info['pid']).terminate()


def daemon():

    config = load_config()

    print("VPN daemon started")

    while True:

        if not vpn_running():
            print("VPN not running, reconnecting...")
            start_vpn(config)

        time.sleep(config["check_interval"])


if __name__ == "__main__":
    daemon()
```